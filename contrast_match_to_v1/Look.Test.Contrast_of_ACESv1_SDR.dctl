// --- CORE SPLINE EVALUATOR ---
__DEVICE__ float eval_ocio_bspline(float x, __CONSTANTREF__ float* knots, int k_cnt, __CONSTANTREF__ float* coefs, int c_cnt) {
    int sets = c_cnt / 3;
    float knStart = knots[0];
    float knEnd = knots[k_cnt - 1];

    if (x <= knStart) {
        return (x - knStart) * coefs[sets] + coefs[sets * 2];
    } else if (x >= knEnd) {
        float t = knEnd - knots[k_cnt - 2];
        float slope = 2.0f * coefs[sets - 1] * t + coefs[sets * 2 - 1];
        float offs = (coefs[sets - 1] * t + coefs[sets * 2 - 1]) * t + coefs[sets * 3 - 1];
        return (x - knEnd) * slope + offs;
    }

    int i = 0;
    for (i = 0; i < k_cnt - 2; ++i) {
        if (x < knots[i + 1]) break;
    }
    float t = x - knots[i];
    return (coefs[i] * t + coefs[sets + i]) * t + coefs[sets * 2 + i];
}

// --- LINEAR LUT INTERPOLATOR ---
__DEVICE__ float interpolate1D(__CONSTANTREF__ float2* p_Table, int p_Size, float p_Val) {
    if (p_Val < p_Table[0].x) return p_Table[0].y;
    if (p_Val >= p_Table[p_Size - 1].x) return p_Table[p_Size - 1].y;

    for (int i = 0; i < p_Size - 1; ++i) {
        if (p_Val >= p_Table[i].x && p_Val < p_Table[i + 1].x) {
            float t = (p_Val - p_Table[i].x) / (p_Table[i + 1].x - p_Table[i].x);
            return (1.0f - t) * p_Table[i].y + t * p_Table[i + 1].y;
        }
    }
    return 0.0f;
}

// --- COSINE SHAPER ---
__DEVICE__ float m_shaper(float J, float x1, float y1, float x2, float y2, float gamma) {
    if (J <= x1) return y1;
    if (J >= x2) return y2;
    float norm = (J - x1) / (x2 - x1);
    return y1 + (y2 - y1) * _powf((1.0f - _cosf(3.14159265f * norm)) / 2.0f, gamma);
}

// --- COLORSPACE: RGB TO JMh ---
__DEVICE__ float3 RGB_to_JMh(float3 rgb) {
    // LMS Transform
    float L = 0.445181072f * rgb.x + 0.34964928f * rgb.y - 0.00112973817f * rgb.z;
    float M = 0.123734139f * rgb.x + 0.613643706f * rgb.y + 0.0563227981f * rgb.z;
    float S = 0.0117006991f * rgb.x + 0.0280607957f * rgb.y + 0.753939092f * rgb.z;

    // Non-linear compression
    float L_p = _powf(_fabs(L), 0.42f) * _copysignf(1.0f, L);
    float M_p = _powf(_fabs(M), 0.42f) * _copysignf(1.0f, M);
    float S_p = _powf(_fabs(S), 0.42f) * _copysignf(1.0f, S);

    float L_a = L_p / (27.13f + _fabs(L_p));
    float M_a = M_p / (27.13f + _fabs(M_p));
    float S_a = S_p / (27.13f + _fabs(S_p));

    // To Aab
    float A = 20.25881f * L_a + 10.129405f * M_a + 0.506470263f * S_a;
    float a = 15480.0f * L_a - 16887.2734f * M_a + 1407.27271f * S_a;
    float b = 1720.0f * L_a + 1720.0f * M_a - 3440.0f * S_a;

    // To JMh
    float J = 0.0f;
    float JMh_M = 0.0f;
    float h = 0.0f;

    if (A > 0.0f) {
        J = 100.0f * _powf(A, 1.13705599f);
        JMh_M = _sqrtf(a * a + b * b);
        h = (a == 0.0f) ? 0.0f : _atan2f(b, a) * 57.2957795f;
        if (h < 0.0f) h += 360.0f;
    }

    return make_float3(J, JMh_M, h);
}

// --- COLORSPACE: JMh TO RGB ---
__DEVICE__ float3 JMh_to_RGB(float3 JMh) {
    float J = JMh.x;
    float M = JMh.y;
    float h = JMh.z;

    float h_rad = h * 0.0174532924f;
    float cos_h = _cosf(h_rad);
    float sin_h = _sinf(h_rad);

    // To Aab
    float A = _powf(J * 0.01f, 0.879464149f);
    float a = M * cos_h;
    float b = M * sin_h;

    // To compressed LMS
    float L_a = 0.0323680267f * A + 2.07657631e-05f * a + 1.3260621e-05f * b;
    float M_a = 0.0323680267f * A - 4.10250432e-05f * a - 1.20174373e-05f * b;
    float S_a = 0.0323680267f * A - 1.01296409e-05f * a - 0.000290076074f * b;

    L_a = _clampf(L_a, -0.99f, 0.99f);
    M_a = _clampf(M_a, -0.99f, 0.99f);
    S_a = _clampf(S_a, -0.99f, 0.99f);

    float L_p = _copysignf(1.0f, L_a) * _powf(_fabs(27.13f * L_a / (1.0f - _fabs(L_a))), 2.38095236f);
    float M_p = _copysignf(1.0f, M_a) * _powf(_fabs(27.13f * M_a / (1.0f - _fabs(M_a))), 2.38095236f);
    float S_p = _copysignf(1.0f, S_a) * _powf(_fabs(27.13f * S_a / (1.0f - _fabs(S_a))), 2.38095236f);

    // Inverse Matrix to RGB
    float R = 2.66705418f * L_p - 1.52505863f * M_p + 0.117925495f * S_p;
    float G = -0.535811901f * L_p + 1.94158077f * M_p - 0.14584811f * S_p;
    float B = -0.0214488022f * L_p - 0.048595503f * M_p + 1.32996523f * S_p;

    return make_float3(R, G, B);
}

// --- MAIN TRANSFORM ---
__DEVICE__ float3 transform(int p_Width, int p_Height, int p_X, int p_Y, float p_R, float p_G, float p_B) {
    float3 rgb = make_float3(p_R, p_G, p_B);

    // Convert ACES to JMh
    float3 JMh = RGB_to_JMh(rgb);
    float J = JMh.x / 400.0f;
    float M = JMh.y;
    float h = JMh.z;

    // Adjust J (lightness)
    if (j_mode == MODE_J_SPLINE) {
        J = eval_ocio_bspline(J, j_knots, 18, j_coefs, 51);
    } else {
        // Simple 1D LUT mockup (lerp between 0 and 1 for this example)
        J = interpolate1D( J_TABLE, 1024, J);
    }

    // Adjust M (colorfulness)
    float gain = 1.0f;
    if (m_mode == MODE_M_SPLINE) {
        gain = _fmaxf(0.0f, eval_ocio_bspline(J, m_knots, 9, m_coefs, 24));
    } else if (m_mode == MODE_M_COSINE) {
        gain = m_shaper(J, x_lower, y_lower, x_upper, y_upper, cos_gamma);
    } else if (m_mode == MODE_M_CONSTANT) {
        gain = const_gain;
    }

    M *= gain;

    // Back to RGB
    float3 out_rgb = JMh_to_RGB(make_float3(J * 400.0f, M, h));


    // Plot curve overlay
    if (show_M_overlay) {
        // Plot covers Full frame space
        float box_x_min = 0.0f;
        float box_x_max = 1.0f;
        float box_y_min = 0.0f;
        float box_y_max = 1.0f;

        if (overlay_location == OL_TL) {
            box_x_max = 0.5f; box_y_min = 0.5f;
        } else if (overlay_location == OL_TR) {
            box_x_min = 0.5f; box_y_min = 0.5f;
        } else if (overlay_location == OL_BL) {
            box_x_max = 0.5f; box_y_max = 0.5f;
        } else if (overlay_location == OL_BR) {
            box_x_min = 0.5f; box_y_max = 0.5f;
        }

        // Current pixel position in normalized coordinates
        float norm_x = (float)p_X / (float)p_Width;
        // Flip Y so bottom of screen corresponds to lower values
        float norm_y = 1.0f - ((float)p_Y / (float)p_Height);

        if (norm_x >= box_x_min && norm_x <= box_x_max && norm_y >= box_y_min && norm_y <= box_y_max) {
            // Local map coordinates inside the chart box
            float u = (norm_x - box_x_min) / (box_x_max - box_x_min); // Map to 0.0 -> 1.0 (X Axis: J)
            float v = (norm_y - box_y_min) / (box_y_max - box_y_min); // Map to 0.0 -> 1.0 (Y Axis: M Gain)

            // Define vertical stretch for Gain: v of 0.0 is gain 0.5, v of 1.0 is gain 2.0
            float plot_floor = 0.5f;
            float plot_ceiling = 2.5f;
            float plot_gain = plot_floor + v * (plot_ceiling - plot_floor);

            // Calculate the actual Gain value for position 'u'
            float current_curve_gain = 1.0f;
            if (m_mode == MODE_M_SPLINE) {
                current_curve_gain = _fmaxf(0.0f, eval_ocio_bspline(u, m_knots, 9, m_coefs, 24));
            } else if (m_mode == MODE_M_COSINE) {
                current_curve_gain = m_shaper(u, x_lower, y_lower, x_upper, y_upper, cos_gamma);
            } else if (m_mode == MODE_M_CONSTANT) {
                current_curve_gain = const_gain;
            }

            // Draw Curve (green line)
            float line_thickness = 0.005f;
            if (_fabs(plot_gain - current_curve_gain) < line_thickness) {
                return make_float3(0.0f, 1.8f, 0.0f); // Bright Green
            }

            // Draw baseline (Gain = 1.0 line)
            if (_fabs(plot_gain - 1.0f) < 0.005f) {
                return make_float3(0.5f, 0.5f, 0.5f); // Gray dashed/solid reference line
            }

            // Draw grid box border
            if (u < 0.003f || u > 0.997f || v < 0.003f || v > 0.997f) {
                return make_float3(1.0f, 1.0f, 1.0f); // White border
            }

        }
    }

    return out_rgb;
}