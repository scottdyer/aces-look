__DEVICE__ float lin_to_stops( float lin) {
    return _log2f(lin)-_log2f(0.18f);
}

__DEVICE__ float stops_to_lin( float stops) {
    return _powf(2., stops + _log2f(0.18f) );
}

// --- CORE SPLINE EVALUATOR ---
__DEVICE__ float eval_ocio_bspline(float x, __CONSTANTREF__ float* knots, int k_cnt, __CONSTANTREF__ float* coefs, int c_cnt) {
    int sets = c_cnt / 3;
    float knStart = knots[0];
    float knEnd = knots[k_cnt - 1];

    if (x <= knStart) {
        return (x - knStart) * coefs[sets] + coefs[sets * 2];
    } else if (x >= knEnd) {
        float t = knEnd - knots[k_cnt - 2];
        float slope = 2.0f * coefs[sets - 1] * t + coefs[sets * 2 - 1];
        float offs = (coefs[sets - 1] * t + coefs[sets * 2 - 1]) * t + coefs[sets * 3 - 1];
        return (x - knEnd) * slope + offs;
    }

    int i = 0;
    for (i = 0; i < k_cnt - 2; ++i) {
        if (x < knots[i + 1]) break;
    }
    float t = x - knots[i];
    return (coefs[i] * t + coefs[sets + i]) * t + coefs[sets * 2 + i];
}

// --- LINEAR LUT INTERPOLATOR ---
__DEVICE__ float interpolate1D(__CONSTANTREF__ float2* table, int Size, float p, int extrapolation_type) {
    // Extrapolate
    if (p < table[0].x) {
        if (extrapolation_type == NONE) {
            return table[0].y;
        } else if (extrapolation_type == LINEAR) {
            float dx = table[1].x - table[0].x;
            float dy = table[1].y - table[0].y;
            float slope = dy / dx;
            return table[0].y + (p - table[0].x) * slope;
        }
    }

    if (p >= table[Size - 1].x) {
        if (extrapolation_type == NONE) {
            return table[Size - 1].y;
        } else if (extrapolation_type == LINEAR) {
            float dx = table[Size - 1].x - table[Size - 2].x;
            float dy = table[Size - 1].y - table[Size - 2].y;
            float slope = dy / dx;
            return table[Size - 1].y + (p - table[Size - 1].x) * slope;
        }
    }

    for (int i = 0; i < Size - 1; ++i) {
        if (p >= table[i].x && p < table[i + 1].x) {
            float t = (p - table[i].x) / (table[i + 1].x - table[i].x);
            return (1.0f - t) * table[i].y + t * table[i + 1].y;
        }
    }
    return 0.0f;
}

__DEVICE__ float3 saturation( float3 rgb, float sat_gain) {

    float luma = 0.2126f * rgb.x + 0.7152f * rgb.y + 0.0722f * rgb.z;

    float out_r = luma + sat_gain * (rgb.x - luma);
    float out_g = luma + sat_gain * (rgb.y - luma);
    float out_b = luma + sat_gain * (rgb.z - luma);

    return make_float3(out_r, out_g, out_b);
}

// --- MAIN TRANSFORM ---
__DEVICE__ float3 transform(int p_Width, int p_Height, int p_X, int p_Y, float p_R, float p_G, float p_B) {
    float3 rgb = make_float3(p_R, p_G, p_B);

    // Matrix to working space, if other than AP0
    float3 rgb_working = rgb;
    if (primaries == PRIMARIES_AP1) {
        rgb_working.x =  1.45143932f * rgb.x + -0.23651075f * rgb.y + -0.21492857f * rgb.z;
        rgb_working.y = -0.07655377f * rgb.x +  1.17622970f * rgb.y + -0.09967593f * rgb.z;
        rgb_working.z =  0.00831615f * rgb.x + -0.00603245f * rgb.y +  0.99771630f * rgb.z;
    }

    // Convert to log (stop) space to apply curves
    rgb_working.x = lin_to_stops( rgb_working.x);
    rgb_working.y = lin_to_stops( rgb_working.y);
    rgb_working.z = lin_to_stops( rgb_working.z);

    // Adjust contrast
    if (curve_mode == MODE_SPLINE) {
        rgb_working.x = eval_ocio_bspline(rgb_working.x, c_knots, 10, c_coefs, 27);
        rgb_working.y = eval_ocio_bspline(rgb_working.y, c_knots, 10, c_coefs, 27);
        rgb_working.z = eval_ocio_bspline(rgb_working.z, c_knots, 10, c_coefs, 27);
    }

    if (curve_mode == MODE_CTL_LUT) {
        rgb_working.x = interpolate1D( CTL_LUT, CTL_LUT_SIZE, rgb_working.x, extrapolation_type);
        rgb_working.y = interpolate1D( CTL_LUT, CTL_LUT_SIZE, rgb_working.y, extrapolation_type);
        rgb_working.z = interpolate1D( CTL_LUT, CTL_LUT_SIZE, rgb_working.z, extrapolation_type);
    }

    // Convert back to linear
    rgb_working.x = stops_to_lin( rgb_working.x);
    rgb_working.y = stops_to_lin( rgb_working.y);
    rgb_working.z = stops_to_lin( rgb_working.z);

    // Adjust sat (colorfulness)
    rgb_working = saturation( rgb_working, sat);

    // Matrix back to AP0, if working spaces is not AP0
    float3 out_rgb = rgb_working;
    if (primaries == PRIMARIES_AP1) {
        out_rgb.x =  0.69545224f * rgb_working.x +  0.14067870f * rgb_working.y +  0.16386906f * rgb_working.z;
        out_rgb.y =  0.04479456f * rgb_working.x +  0.85967112f * rgb_working.y +  0.09553432f * rgb_working.z;
        out_rgb.z = -0.00552588f * rgb_working.x +  0.00402521f * rgb_working.y +  1.00150067f * rgb_working.z;
    }

    return out_rgb;
}